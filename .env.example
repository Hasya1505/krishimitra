# Copy this file to .env and fill in real values before running/deploying.

# Any long random string - used to sign session cookies
SECRET_KEY=change-this-to-a-long-random-string

# Free GNews API key from https://gnews.io/register (no credit card required)
# If left blank, the landing page will show a small set of sample news cards instead.
GNEWS_API_KEY=

FLASK_ENV=production
